# 文本统一按 LF 入库，避免 Linux CI 比对被 CRLF 绊倒
*.mmd text eol=lf
*.svg text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.excalidraw text eol=lf
*.drawio text eol=lf
*.json text eol=lf
*.cpp text eol=lf
*.hpp text eol=lf
*.h text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.csv text eol=lf
Makefile text eol=lf
.clang-format text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

