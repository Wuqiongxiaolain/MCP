<mxfile host="graphmcp" agent="graphmcp/1.0" type="device">
  <diagram name="微服务示例" id="d1">
    <mxGraphModel dx="800" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="cluster" value="Service Cluster" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="108" width="199.5" height="224" as="geometry"/>
        </mxCell>
        <mxCell id="gateway" value="API Gateway" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="57" y="20" width="125.5" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="order" value="Order Service" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="cluster">
          <mxGeometry x="28.5" y="36" width="142.5" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="payment" value="Payment Service" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="cluster">
          <mxGeometry x="20" y="160" width="159.5" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="db" value="MySQL" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="69.75" y="392" width="100" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="edge1" value="http" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="gateway" target="order">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge2" value="rpc" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="order" target="payment">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge3" value="sql" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="payment" target="db">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
